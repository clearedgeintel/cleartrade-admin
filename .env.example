# ─── Auth (Clerk) ─────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ─── Admin DB (Supabase Postgres) ─────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/cleartrade_admin

# ─── Billing (Stripe) ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...

# Used for absolute redirect URLs (Checkout success / Customer Portal return).
# Leave unset in dev — the API routes fall back to the request origin.
# NEXT_PUBLIC_APP_URL=https://admin.cleartrade.ai

# ─── Provisioning (Railway) — wired up in a later commit ──────
# RAILWAY_API_TOKEN=
# RAILWAY_PROJECT_ID=
# RAILWAY_TEMPLATE_ID=
# SHARED_ANTHROPIC_KEY=

# ─── DNS (Cloudflare) — wired up in a later commit ────────────
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ZONE_ID=
# BASE_DOMAIN=yourdomain.com
