# ─── Auth (Clerk) ─────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ─── Admin DB (Supabase Postgres) ─────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/cleartrade_admin

# ─── Admin panel access ───────────────────────────────────────
# Comma-separated allowlist of emails that can see /admin.
ADMIN_EMAILS=you@example.com

# ─── Secrets encryption ───────────────────────────────────────
# AES-256 key, base64-encoded (32 bytes). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Rotating this key means you need to re-encrypt every row in
# tenant_secrets — do NOT lose or change it without a migration plan.
TENANT_SECRETS_KEY=

# ─── Billing (Stripe) ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...

# Used for absolute redirect URLs (Checkout success / Customer Portal return).
# Leave unset in dev — the API routes fall back to the request origin.
# NEXT_PUBLIC_APP_URL=https://admin.cleartrade.ai

# ─── Provisioning (Railway) ───────────────────────────────────
RAILWAY_API_TOKEN=
RAILWAY_PROJECT_ID=
BOT_DOCKER_IMAGE=ghcr.io/cleartrade/alpaca-trader:latest
SHARED_ANTHROPIC_KEY=

# ─── Tenant DB isolation (Supabase Management API) ────────────
# Used to create a fresh Supabase project per tenant. Get the management
# token at supabase.com/dashboard/account/tokens; ORG_ID is in the URL of
# your org dashboard.
SUPABASE_MANAGEMENT_TOKEN=
SUPABASE_ORG_ID=

# ─── DNS (Cloudflare) ─────────────────────────────────────────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
BASE_DOMAIN=cleartrade.ai
