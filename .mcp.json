{
  "mcpServers": {
    "postgres": {
      "type": "stdio",
      "command": "cmd",
      "args": [
        "/c",
        "uvx",
        "--python",
        "3.12",
        "postgres-mcp",
        "--access-mode=restricted"
      ],
      "env": {
        "DATABASE_URI": "${DATABASE_URL}"
      }
    }
  }
}
